<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Book Appointment | Reha Beauty Clinic</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

<style>

body{
margin:0;
font-family:'Poppins',sans-serif;
background:#fff7f9;
color:#333;
text-align:center;
}

h1{
font-family:'Playfair Display';
}

/* HERO */

.hero{
height:45vh;
background:url("https://images.unsplash.com/photo-1522335789203-aabd1fc54bc9");
background-size:cover;
background-position:center;
display:flex;
align-items:center;
justify-content:center;
color:white;
position:relative;
}

.hero::after{
content:"";
position:absolute;
width:100%;
height:100%;
background:rgba(0,0,0,0.45);
}

.hero h1{
position:relative;
font-size:48px;
}

/* BOOKING SECTION */

.booking{
max-width:900px;
margin:auto;
padding:60px 20px;
}

.form-box{
background:white;
padding:40px;
border-radius:18px;
box-shadow:0 20px 40px rgba(0,0,0,0.15);
text-align:left;
}

input,select,textarea{
width:100%;
padding:12px;
margin-top:10px;
margin-bottom:15px;
border-radius:8px;
border:1px solid #ccc;
font-family:'Poppins';
}

button{
background:linear-gradient(45deg,#d6336c,#ff8fab);
border:none;
color:white;
padding:12px 25px;
border-radius:30px;
cursor:pointer;
font-size:16px;
}

/* OPTIONS */

.options{
display:flex;
gap:20px;
margin-top:20px;
}

.option-card{
flex:1;
background:white;
padding:25px;
border-radius:15px;
box-shadow:0 15px 30px rgba(0,0,0,0.15);
cursor:pointer;
transition:0.3s;
}

.option-card:hover{
transform:translateY(-6px);
}

/* WHATSAPP */

.whatsapp{
position:fixed;
bottom:25px;
right:25px;
background:#25D366;
color:white;
padding:16px;
border-radius:50%;
font-size:24px;
text-decoration:none;
}

@media(max-width:768px){

.options{
flex-direction:column;
}

.hero h1{
font-size:34px;
}

}

</style>

</head>

<body>

<section class="hero">
<h1>Book Appointment</h1>
</section>

<section class="booking">

<div class="options">

<div class="option-card">
<h3>📅 Book Online</h3>
<p>Select service, date and time.</p>
</div>

<div class="option-card">
<h3>💬 WhatsApp Booking</h3>
<p>Chat with us directly.</p>
<a href="https://wa.me/9622212234">Open WhatsApp</a>
</div>

<div class="option-card">
<h3>📞 Call Us</h3>
<p>Speak with our team instantly.</p>
<a href="tel:9622212234">Call Now</a>
</div>

</div>

<br><br>

<div class="form-box">

<h2>Appointment Details</h2>

<form id="bookingForm">

<label>Full Name</label>
<input type="text" required>

<label>Phone Number</label>
<input type="text" required>

<label>Select Service</label>

<select>
<option>Bridal Makeup</option>
<option>Hair Styling</option>
<option>Facial Treatment</option>
<option>Skin Care</option>
<option>Hair Coloring</option>
</select>

<label>Select Date & Time</label>
<input type="text" id="calendar">

<label>Additional Notes</label>
<textarea placeholder="Any special requests"></textarea>

<button type="submit">Confirm Booking</button>

</form>

</div>

</section>

<a href="https://wa.me/9622212234" class="whatsapp">💬</a>

<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>

flatpickr("#calendar",{
enableTime:true,
dateFormat:"Y-m-d H:i",
minDate:"today"
});

document.getElementById("bookingForm").addEventListener("submit",function(e){

e.preventDefault();

alert("Appointment request sent! We will contact you shortly.");

});

</script>

</body>
</html>
